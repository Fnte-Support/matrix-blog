gn-items: center;\n        justify-content: center;\n      }\n\n      .mx-article-coffeeguide .mx-toc-drawer {\n        display: block;\n        position: fixed;\n        inset: 0;\n        z-index: 60;\n        pointer-events: none;\n      }\n\n      .mx-article-coffeeguide .mx-toc-drawer.is-open {\n        pointer-events: auto;\n      }\n\n      .mx-article-coffeeguide .mx-toc-overlay {\n        position: absolute;\n        inset: 0;\n        background: rgba(0,0,0,0.35);\n        opacity: 0;\n        transition: opacity .25s ease;\n      }\n\n      .mx-article-coffeeguide .mx-toc-drawer.is-open .mx-toc-overlay {\n        opacity: 1;\n      }\n\n      .mx-article-coffeeguide .mx-toc-panel {\n        position: absolute;\n        right: 0;\n        top: 0;\n        width: min(86vw, 340px);\n        height: 100%;\n        background: #fff;\n        transform: translateX(100%);\n        transition: transform .25s ease;\n        padding: 24px 20px;\n        overflow-y: auto;\n      }\n\n      .mx-article-coffeeguide .mx-toc-drawer.is-open .mx-toc-panel {\n        transform: translateX(0);\n      }\n\n      .mx-article-coffeeguide .mx-toc-close {\n        appearance: none;\n        border: 0;\n        background: none;\n        color: var(--mx-deep);\n        font-size: 28px;\n        line-height: 1;\n        padding: 0;\n        margin-left: auto;\n        display: block;\n        cursor: pointer;\n      }\n    }\n\n    @media (max-width: 900px) {\n      .mx-article-coffeeguide .mx-shell {\n        padding: 0 18px 84px;\n      }\n\n      .mx-article-coffeeguide .mx-product-rail,\n      .mx-article-coffeeguide .mx-icon-grid,\n      .mx-article-coffeeguide .mx-image-grid {\n        grid-template-columns: 1fr;\n      }\n\n      .mx-article-coffeeguide h1 {\n        font-size: 34px;\n      }\n\n      .mx-article-coffeeguide h2 {\n        font-size: 28px;\n        margin-top: 56px;\n      }\n\n      .mx-article-coffeeguide p {\n        font-size: 16px;\n      }\n\n      .mx-article-coffeeguide .mx-step {\n        grid-template-columns: 46px 1fr;\n      }\n\n      .mx-article-coffeeguide .mx-step-no {\n        width: 46px;\n        height: 46px;\n        font-size: 20px;\n      }\n    }\n  </style>\n\n  <article class=\"mx-article-coffeeguide\">\n    <div class=\"mx-shell\">\n      <aside class=\"mx-toc\" aria-label=\"文章目錄\">\n        <div class=\"mx-toc-inner\">\n          <div class=\"mx-toc-title\">目錄</div>\n          <ol>\n            <li><a href=\"#mx-intro\">前言</a></li>\n            <li><a href=\"#mx-why-need-system\">先解決新手卡點</a></li>\n            <li><a href=\"#mx-why-practice-pack\">為什麼選練功包</a></li>\n            <li><a href=\"#mx-first-beans\">第一包豆怎麼選</a></li>\n            <li><a href=\"#mx-bean-list\">8 款豆子介紹</a></li>\n            <li><a href=\"#mx-compare\">方案比較</a></li>\n            <li><a href=\"#mx-who\">適合什麼人</a></li>\n            <li><a href=\"#mx-how-to-use\">怎麼練才會進步</a></li>\n            <li><a href=\"#mx-m2pro\">搭配 M2 PRO</a></li>\n            <li><a href=\"#mx-faq\">FAQ</a></li>\n          </ol>\n        </div>\n      </aside>\n\n      <button class=\"mx-toc-fab\" type=\"button\" aria-label=\"開啟目錄\" id=\"mxTocFab\">≡</button>\n\n      <div class=\"mx-toc-drawer\" id=\"mxTocDrawer\" aria-hidden=\"true\">\n        <div class=\"mx-toc-overlay\" id=\"mxTocOverlay\"></div>\n        <div class=\"mx-toc-panel\" role=\"dialog\" aria-modal=\"true\" aria-label=\"文章目錄\">\n          <button class=\"mx-toc-close\" type=\"button\" id=\"mxTocClose\" aria-label=\"關閉目錄\">×</button>\n          <div class=\"mx-toc-title\" style=\"margin-top:18px;\">目錄</div>\n          <ol style=\"list-style:none; padding:0; margin:0; display:grid; gap:10px;\">\n            <li><a href=\"#mx-intro\">前言</a></li>\n            <li><a href=\"#mx-why-need-system\">先解決新手卡點</a></li>\n            <li><a href=\"#mx-why-practice-pack\">為什麼選練功包</a></li>\n            <li><a href=\"#mx-first-beans\">第一包豆怎麼選</a></li>\n            <li><a href=\"#mx-bean-list\">8 款豆子介紹</a></li>\n            <li><a href=\"#mx-compare\">方案比較</a></li>\n            <li><a href=\"#mx-who\">適合什麼人</a></li>\n            <li><a href=\"#mx-how-to-use\">怎麼練才會進步</a></li>\n            <li><a href=\"#mx-m2pro\">搭配 M2 PRO</a></li>\n            <li><a href=\"#mx-faq\">FAQ</a></li>\n          </ol>\n        </div>\n      </div>\n\n      <main class=\"mx-main\">\n        <header class=\"mx-hero\">\n          <nav class=\"mx-breadcrumb\" aria-label=\"麵包屑\">\n            <a href=\"https://www.matrix.com.tw/\">首頁</a> ／\n            <a href=\"https://dailycoffee.matrix.com.tw/\">專欄</a> ／\n            <span>手沖咖啡初學者購買指南</span>\n          </nav>\n\n          <div class=\"mx-kicker\">☕ 手沖入門 × 練習選豆指南</div>\n\n          <h1>手沖咖啡初學者購買指南：<br>為什麼選擇練功包，比單買咖啡豆更適合入門</h1>\n\n          <p class=\"mx-lead\">\n            剛開始學手沖，真正最容易卡住的，往往不是沒有器材，而是買了豆之後，還是不知道自己是選錯豆、沖錯參數，還是根本還喝不懂差異。對新手來說，比起一開始就單買一大包單品豆，能夠保留<span class=\"mx-highlight\">「先感受、再修正」</span>節奏的練習方式，通常更容易真正進步。\n          </p>\n\n          <div class=\"mx-meta\">\n            <span>📅 發布日期：2026-04-20</span>\n            <span>📝 文章類型：手沖入門選購指南</span>\n            <span>🔎 核心關鍵字：手沖咖啡初學者／咖啡豆推薦／練功包</span>\n          </div>\n\n          <figure class=\"mx-cover\">\n            <img src=\"https://img.1shop.tw/dmLqpoYEVREYo9xRbZy2XK7l/41brG7JDYpJQO2ewlxW5ywvg/original.jpg\" alt=\"沐萃手沖咖啡豆修正練功包商品主圖\" />\n            <figcaption>從練功包開始，不只是試喝不同風味，而是替手沖初學者保留一次真正的修正機會。</figcaption>\n          </figure>\n        </header>\n\n        <section id=\"mx-intro\">\n          <h2>前言：新手真正卡住的，往往不是器材，而是「買了也不知道怎麼修正」</h2>\n          <p>\n            對手沖咖啡初學者來說，最卡的通常不是沒有器材，而是買了豆之後，還是不知道自己到底是選錯豆、沖錯參數，還是根本還喝不懂差異。尤其當一支豆子只有一次機會時，第一杯沒沖好，往往也很難知道問題到底出在哪裡。\n          </p>\n          <p>\n            也因此，對入門者來說，真正有價值的商品不只是「口味很多」，而是能不能保留一次修正空間。當一款商品把「第一次先感受、第二次再調整」這件事設計進去，它帶來的就不只是方便，而是一條比較不容易中斷的學習路徑。\n          </p>\n\n          <div class=\"mx-callout\">\n            <div class=\"mx-callout-title\">先看結論</div>\n            <p style=\"margin-bottom:0;\">\n              如果你現在最在意的是：<span class=\"mx-highlight\">第一包豆怎麼買比較不容易浪費預算、也不容易卡住進度</span>，那麼比起單買一大包單品豆，練功包通常會更像一套替新手設計好的學習起點。\n            </p>\n          </div>\n        </section>\n\n        <section id=\"mx-why-need-system\">\n          <h2>為什麼比起單買咖啡豆，新手更需要一套能修正的練習方式？</h2>\n          <p>\n            很多人一開始都很認真，買了濾杯、手沖壺，也看了不少教學，但真正進入練習之後，挫折感往往會出現在下面這幾個地方：\n          </p>\n\n          <ul class=\"mx-pain-list\">\n            <li>\n              <strong>喝到不喜歡的味道，卻不知道問題出在哪裡。</strong><br>\n              太酸、太淡、太苦、太空，未必是豆子不好，也可能是研磨度、水量、注水節奏或萃取時間沒有抓準。\n            </li>\n            <li>\n              <strong>換了幾支豆子，卻還是建立不起自己的判斷基準。</strong><br>\n              今天喝衣索比亞、明天喝巴西，看起來好像試了不少，實際上卻還是不太確定自己到底偏好明亮果酸，還是厚實堅果調。\n            </li>\n            <li>\n              <strong>每一次沖煮都像重新開始，沒有真正累積成進步。</strong><br>\n              第一杯覺得哪裡怪怪的，下一次卻不是換了豆子，就是忘了上次哪個環節出問題，結果同樣的困惑一直重複。\n            </li>\n            <li>\n              <strong>看了很多教學，實際喝進嘴裡還是很難對上。</strong><br>\n              你知道大家在講流速、酸甜平衡、萃取感，但真正回到自己的杯子裡時，還是很難判斷這些差異到底是怎麼形成的。\n            </li>\n            <li>\n              <strong>最容易浪費的不是豆子本身，而是那些沒有被修正的嘗試。</strong><br>\n              對新手來說，最可惜的通常不是買錯一包豆，而是第一杯喝不懂，第二杯又沒有機會修正，最後整段學習就停在模糊印象裡。\n            </li>\n          </ul>\n\n          <figure class=\"mx-image-block\">\n            <img src=\"https://img.fnte.com.tw/product/matrix/MucraftsBeans_m2pro/2.jpg\" alt=\"第一次先感受、第二次再修正圖解\" />\n            <figcaption>第一次先感受、第二次再修正｜對新手來說，比多喝一包更重要的是保留一次真正修正的機會。</figcaption>\n          </figure>\n          <div class=\"mx-quote\">\n            入門階段真正重要的，從來不是先買到最厲害的豆子，而是先找到一種能讓自己持續練、看得見差異，也有機會修正的方式。\n          </div>\n\n          <p>\n            當新手有了前後比較的空間，學習速度通常會比一直換豆、一直重來快得多。也正因如此，真正有幫助的商品不只是讓你一次喝到不同風味而已，而是能不能把<span class=\"mx-highlight\">「第一次先感受、第二次再修正」</span>這件事，做進整個練習流程裡。\n          </p>\n\n        </section>\n\n        <section id=\"mx-why-practice-pack\">\n          <h2>為什麼手沖咖啡初學者更適合從練功包開始？</h2>\n          <p>\n            在這樣的前提下，練功包之所以適合入門，不是因為它看起來選擇很多，而是因為它剛好對應了新手最常卡住的幾個問題。\n          </p>\n\n          <figure class=\"mx-image-block\">\n            <img src=\"https://img.fnte.com.tw/product/matrix/MucraftsBeans_m2pro/3.jpg\" alt=\"為什麼手沖咖啡初學者更適合從練功包開始\" />\n            <figcaption>練功包不是單純試喝，而是替初學者把「認識風味、建立比較、保留修正」整合成同一套練習流程。</figcaption>\n          </figure>\n\n          <div class=\"mx-icon-grid\">\n            <div class=\"mx-icon-card\">\n              <div class=\"mx-icon\">①</div>\n              <h3>一次接觸多風味，才比較快建立味覺基準</h3>\n              <p>不同產區、處理法與焙度同時放進一個練習包裡，能幫你更快知道自己偏好果酸、花香，還是堅果巧克力調。</p>\n            </div>\n            <div class=\"mx-icon-card\">\n              <div class=\"mx-icon\">②</div>\n              <h3>預算不是花在亂試，而是花在有方向的練習</h3>\n              <p>不是今天隨便買一包、明天再憑感覺換一包，而是用同一套練習邏輯持續比較，學習效率會高很多。</p>\n            </div>\n            <div class=\"mx-icon-card\">\n              <div class=\"mx-icon\">③</div>\n              <h3>真正有價值的不是 16 包，而是每款都保留第二次修正機會</h3>\n              <p>一袋內含 8 款不同風味熟豆，每一款各配置 2 包 18g，不是多送，而是刻意保留修正的機會。</p>\n            </div>\n            <div class=\"mx-icon-card\">\n              <div class=\"mx-icon\">④</div>\n              <h3>有參數小卡，新手不會從第一杯就迷路</h3>\n              <p>先照著參數小卡沖第一杯，再在第二杯開始修正，才能真正看見流速、酸甜與萃取感之間的差異。</p>\n            </div>\n          </div>\n\n          <div class=\"mx-callout\">\n            <div class=\"mx-callout-title\">這包真正厲害的地方</div>\n            <p style=\"margin-bottom:0;\">\n              它賣的不是「口味很多」，而是<span class=\"mx-highlight\">一套完整的修正流程</span>。第一包先看、先喝、先記住；第二包再調整研磨、水量或注水節奏，真正完成一次有效學習。\n            </p>\n          </div>\n        </section>\n\n        <section id=\"mx-first-beans\">\n          <h2>手沖咖啡初學者第一包豆怎麼選？</h2>\n          <p>\n            如果你現在連自己喜歡偏果酸、偏花香，還是偏堅果巧克力都還不確定，那第一包豆最重要的不是「選最熱門」，而是<span class=\"mx-highlight\">選一個能幫你建立比較基準的組合</span>。\n          </p>\n          <p>\n            與其一開始就假設自己喜歡某一類型，不如先透過有順序的練習，把自己的口味輪廓慢慢找出來。對完全新手來說，建議先從中焙到中深焙喝起，先理解甜感、堅果感與厚度；等你對注水穩定度與基本風味有感之後，再往淺焙與發酵處理豆前進。\n          </p>\n\n          <div class=\"mx-steps\">\n            <div class=\"mx-step\">\n              <div class=\"mx-step-no\">1</div>\n              <div>\n                <h3 style=\"margin:0 0 8px;\">先從好理解的風味開始</h3>\n                <p style=\"margin:0;\">中焙到中深焙通常比較容易建立「原來手沖也可以很順口」的信心。</p>\n              </div>\n            </div>\n            <div class=\"mx-step\">\n              <div class=\"mx-step-no\">2</div>\n              <div>\n                <h3 style=\"margin:0 0 8px;\">再往果香、花香與發酵風味延伸</h3>\n                <p style=\"margin:0;\">當你已經能分辨甜感、厚度與基本平衡後，再喝淺焙會更容易抓到層次。</p>\n              </div>\n            </div>\n            <div class=\"mx-step\">\n              <div class=\"mx-step-no\">3</div>\n              <div>\n                <h3 style=\"margin:0 0 8px;\">不要只喝一次就下結論</h3>\n                <p style=\"margin:0;\">真正重要的不是第一杯有沒有完美，而是第二杯能不能根據自己的判斷修正回來。</p>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        <section id=\"mx-bean-list\">\n          <h2>沐萃練功包 8 款豆子具體介紹：每一支更適合哪種新手？</h2>\n          <p>\n            目前豆單橫跨水洗、日曬、蜜處理與發酵處理，也涵蓋淺焙、淺中焙、中焙到中深焙，剛好可以讓入門者有系統地建立自己的風味地圖。\n          </p>\n\n          <div class=\"mx-image-grid\">\n            <figure class=\"mx-image-block\">\n              <img src=\"https://img.1shop.tw/dmLqpoYEVREYo9xRbZy2XK7l/LWx9yMqPlG7JWMr1lEpb1wO7/original.jpg\" alt=\"沐萃練功包 8 款豆子介紹圖一\" />\n              <figcaption>8 款風味豆單與內容示意｜適合拿來建立風味比較基準。</figcaption>\n            </figure>\n            <figure class=\"mx-image-block\">\n              <img src=\"https://img.1shop.tw/dmLqpoYEVREYo9xRbZy2XK7l/g9M05D783DyArMwBlRoA6Z1W/original.jpg\" alt=\"沐萃練功包 8 款豆子介紹圖二\" />\n              <figcaption>不同產區、處理法與焙度的練習配置，能幫助新手更快看見差異。</figcaption>\n            </figure>\n          </div>\n\n          <div class=\"mx-beans\">\n            <div class=\"mx-bean-card\">\n              <h3>1. 衣索比亞 古吉 水風鈴</h3>\n              <div class=\"mx-chip-row\">\n                <span class=\"mx-chip\">水洗</span>\n                <span class=\"mx-chip\">淺焙</span>\n                <span class=\"mx-chip\">檸檬卡士達／水蜜桃／糯米荔枝</span>\n              </div>\n              <p>這支很適合想理解「乾淨、明亮、花果感清楚」是什麼的新手。若你常聽人說淺焙水洗有透明感，卻一直抓不到，那它會是很好的入門參考。</p>\n            </div>\n\n            <div class=\"mx-bean-card\">\n              <h3>2. 衣索比亞 西達摩 桃子甜心</h3>\n              <div class=\"mx-chip-row\">\n                <span class=\"mx-chip\">日曬</span>\n                <span class=\"mx-chip\">淺焙</span>\n                <span class=\"mx-chip\">水蜜桃／可爾必思／荔枝果凍／橙花</span>\n              </div>\n              <p>如果你想感受日曬豆那種比較張揚、甜感比較明顯、香氣比較外放的個性，這支就很適合。它也很適合拿來和前一支水洗做對照。</p>\n            </div>\n\n            <div class=\"mx-bean-card\">\n              <h3>3. 哥斯大黎加 卡內特 莫札特</h3>\n              <div class=\"mx-chip-row\">\n                <span class=\"mx-chip\">葡萄乾蜜處理</span>\n                <span class=\"mx-chip\">淺焙</span>\n                <span class=\"mx-chip\">香檳葡萄／水果軟糖／大吉嶺紅茶</span>\n              </div>\n              <p>這支適合已經開始分得出酸甜差異、想再往更細緻甜感與茶感前進的新手。若你不想一下子跳到太強烈的發酵感，它會是很好的過渡豆。</p>\n            </div>\n\n            <div class=\"mx-bean-card\">\n              <h3>4. 哥倫比亞 哈芭安赫爾</h3>\n              <div class=\"mx-chip-row\">\n                <span class=\"mx-chip\">乳酸發酵水洗</span>\n                <span class=\"mx-chip\">淺焙</span>\n                <span class=\"mx-chip\">哈蜜瓜／水蜜桃優格／牛奶焦糖</span>\n              </div>\n              <p>這支很適合想認識「發酵處理豆為什麼會有乳酸感、優格感」的新手。它通常能幫你很快理解，特殊處理不是只有香，而是連口感和酸質都會改變。</p>\n            </div>\n\n            <div class=\"mx-bean-card\">\n              <h3>5. 哥倫比亞 內格雷特 百香卡多索</h3>\n              <div class=\"mx-chip-row\">\n                <span class=\"mx-chip\">發酵水洗</span>\n                <span class=\"mx-chip\">淺焙</span>\n                <span class=\"mx-chip\">百香果／蘋果西打／荔枝／水果糖</span>\n              </div>\n              <p>如果你喜歡辨識度很高、聞得出來也喝得出來的風味，這支通常會很有記憶點。它特別適合想練習觀察香氣張力與果感明確度的人。</p>\n            </div>\n\n            <div class=\"mx-bean-card\">\n              <h3>6. 哥斯大黎加 中央谷地 津卡蜜熊</h3>\n              <div class=\"mx-chip-row\">\n                <span class=\"mx-chip\">黃蜜</span>\n                <span class=\"mx-chip\">淺中焙</span>\n                <span class=\"mx-chip\">柑橘／葡萄柚／榛果／蜂蜜餅乾</span>\n              </div>\n              <p>這支很適合站在「怕太酸，但又不想只喝厚重款」之間的新手。它像是一個橋樑，能讓你從果香型豆慢慢走向更平衡、更耐喝的方向。</p>\n            </div>\n\n            <div class=\"mx-bean-card\">\n              <h3>7. 秘魯 胡寧 聖文森莊園</h3>\n              <div class=\"mx-chip-row\">\n                <span class=\"mx-chip\">水洗</span>\n                <span class=\"mx-chip\">中焙</span>\n                <span class=\"mx-chip\">橘皮／柳橙／李子／杏仁／焦糖</span>\n              </div>\n              <p>如果你希望第一支就不要太難，這支通常很適合。它比較容易幫新手理解中焙的平衡感，也比較容易在甜感、果調與堅果感之間找到交集。</p>\n            </div>\n\n            <div class=\"mx-bean-card\">\n              <h3>8. 巴西 喜朵拉 克里阿多</h3>\n              <div class=\"mx-chip-row\">\n                <span class=\"mx-chip\">日曬</span>\n                <span class=\"mx-chip\">中深焙</span>\n                <span class=\"mx-chip\">堅果／奶油／榛果／黑巧克力</span>\n              </div>\n              <p>如果你本身比較怕酸，或者平常喝咖啡就偏好厚實、堅果、巧克力路線，建議可以先從這支開始。它通常比較容易讓新手建立「手沖也可以很好入口」的信心。</p>\n            </div>\n          </div>\n        </section>\n\n        <section id=\"mx-compare\">\n          <h2>練功包、單買單一咖啡豆、M2 PRO＋練功包，該怎麼選？</h2>\n          <p>如果你現在是在「先買豆試試看」和「一次把整套練習路徑建好」之間猶豫，下面這張表會比較好判斷。</p>\n\n          <div class=\"mx-compare\">\n            <table>\n              <thead>\n                <tr>\n                  <th>方案</th>\n                  <th>適合對象</th>\n                  <th>優點</th>\n                  <th>可能限制</th>\n                </tr>\n              </thead>\n              <tbody>\n                <tr>\n                  <td>練功包</td>\n                  <td>剛入門、還不知道自己喜歡什麼風味的人</td>\n                  <td>一次認識 8 款豆、每款可修正一次、附沖煮小卡</td>\n                  <td>喝完後若喜歡特定風味，之後仍要再找對應單品</td>\n                </tr>\n                <tr>\n                  <td>單買單一咖啡豆</td>\n                  <td>已有明確偏好的人</td>\n                  <td>可集中研究同一支豆的參數</td>\n                  <td>新手容易喝不懂，也較難建立比較基準</td>\n                </tr>\n                <tr>\n                  <td>M2 PRO＋練功包</td>\n                  <td>已準備認真練習手沖的人</td>\n                  <td>豆子與秤一起到位，更容易建立穩定流程</td>\n                  <td>預算高於單買練功包，但完整度更高</td>\n                </tr>\n              </tbody>\n            </table>\n          </div>\n\n          <div class=\"mx-product-rail\">\n            <article class=\"mx-product-card\">\n              <img src=\"https://img.1shop.tw/dmLqpoYEVREYo9xRbZy2XK7l/DoBrmR7VlwMgPLroY8wbGZKL/original.jpg\" alt=\"沐萃手沖咖啡豆修正練功包\" />\n              <div class=\"mx-product-body\">\n                <h3 style=\"margin:0;\">沐萃手沖咖啡豆修正練功包</h3>\n                <p style=\"margin:0;\">8 款風味熟豆共 16 入，內附沖煮小卡。適合先感受、再修正的入門練習。</p>\n                <div class=\"mx-price\">\n                  <del>NT$1,200</del>\n                  <strong>NT$1,000</strong>\n                </div>\n                <a class=\"mx-btn\" href=\"https://www.matrix.com.tw/products/%E6%B2%90%E8%90%83%E5%92%96%E5%95%A1-%E6%B2%90%E8%90%83%E6%89%8B%E6%B2%96%E5%92%96%E5%95%A1%E8%B1%86%E4%BF%AE%E6%AD%A3%E7%B7%B4%E5%8A%9F%E5%8C%858%E6%AC%BE%E9%A2%A8\" target=\"_blank\" rel=\"noopener\">立即看練功包</a>\n              </div>\n            </article>\n\n            <article class=\"mx-product-card\">\n              <img src=\"https://img.1shop.tw/dmLqpoYEVREYo9xRbZy2XK7l/DoBrmR7VlwMgP8dbY8wbGZKL/original.jpg\" alt=\"M2 PRO＋練功包組合\" />\n              <div class=\"mx-product-body\">\n                <h3 style=\"margin:0;\">M2 PRO＋練功包組合</h3>\n                <p style=\"margin:0;\">把電子秤與練豆路徑一次備齊，適合準備穩定開始練手沖的人。</p>\n                <div class=\"mx-price\">\n                  <del>NT$3,480</del>\n                  <strong>NT$2,680</strong>\n                </div>\n                <a class=\"mx-btn\" href=\"https://www.matrix.com.tw/products/matrix-x%E6%B2%90%E8%90%83%E5%92%96%E5%95%A1-m2-pro\" target=\"_blank\" rel=\"noopener\">立即看組合</a>\n              </div>\n            </article>\n          </div>\n        </section>\n\n        <section id=\"mx-who\">\n          <h2>練功包適合什麼樣的人？</h2>\n          <div class=\"mx-icon-grid\">\n            <div class=\"mx-icon-card\">\n              <div class=\"mx-icon\">A</div>\n              <h3>完全剛入門的人</h3>\n              <p>你最需要的不是追熱門產區，而是先建立比較能力。一次有 8 種風味方向，會比單買一大包更容易開始。</p>\n            </div>\n            <div class=\"mx-icon-card\">\n              <div class=\"mx-icon\">B</div>\n              <h3>常常覺得有在沖、卻不知道問題出在哪裡的人</h3>\n              <p>每款都有兩包，你終於能把第一杯的觀察帶進第二杯修正，而不是停在「這杯好像怪怪的」。</p>\n            </div>\n            <div class=\"mx-icon-card\">\n              <div class=\"mx-icon\">C</div>\n              <h3>準備把手沖當成固定習慣的人</h3>\n              <p>這類人其實很適合直接看 M2 PRO＋練功包，因為秤與練習包一起到位，更容易把每次調整留下來。</p>\n            </div>\n            <div class=\"mx-icon-card\">\n              <div class=\"mx-icon\">D</div>\n              <h3>想送給剛入門咖啡朋友的人</h3>\n              <p>比起直接送一包風味很主觀的單品豆，練功包更像一套有學習邏輯的入門禮物，接受度通常更高。</p>\n            </div>\n          </div>\n        </section>\n\n        <section id=\"mx-how-to-use\">\n          <h2>初學者怎麼用這款練功包，才真的會進步？</h2>\n          <p>\n            最好的用法，不是把 16 包隨便拆來喝，而是把它當成一套有順序的練習教材。第一輪可以先從巴西、秘魯這類較好理解的中焙到中深焙開始，先把基本注水穩定度、萃取時間感和甜感判斷練起來；第二輪再進到黃蜜、葡萄乾蜜與淺焙水洗；最後再去挑戰乳酸發酵水洗與發酵水洗這類香氣更鮮明的豆子。\n          </p>\n\n          <div class=\"mx-steps\">\n            <div class=\"mx-step\">\n              <div class=\"mx-step-no\">1</div>\n              <div>\n                <h3 style=\"margin:0 0 8px;\">第一包：照著參數小卡沖</h3>\n                <p style=\"margin:0;\">先不要急著追求完美。先看流速、先感受酸甜、先記住這支豆子的第一印象。</p>\n              </div>\n            </div>\n            <div class=\"mx-step\">\n              <div class=\"mx-step-no\">2</div>\n              <div>\n                <h3 style=\"margin:0 0 8px;\">第二包：根據判斷做修正</h3>\n                <p style=\"margin:0;\">你可以調整研磨度、水量，或改一下自己的注水節奏，重新沖一次。</p>\n              </div>\n            </div>\n            <div class=\"mx-step\">\n              <div class=\"mx-step-no\">3</div>\n              <div>\n                <h3 style=\"margin:0 0 8px;\">把前後差異留下來</h3>\n                <p style=\"margin:0;\">這樣你完成的就不只是一杯咖啡，而是一個真正有效的學習循環。</p>\n              </div>\n            </div>\n          </div>\n        </section>\n\n        <section id=\"mx-m2pro\">\n          <h2>如果搭配 M2 PRO，會更容易把每一次修正留下來</h2>\n          <p>\n            若你已經準備開始穩定練習，M2 PRO＋練功包組合會更完整。它的價值不只是把商品綁在一起，而是讓「第一杯按參數沖、第二杯做修正」這件事，變成更穩定可比較的練習流程。\n          </p>\n          <p>\n            對剛進入手沖的人來說，當豆子與電子秤一起到位，你比較不會每次都從零開始，而是能慢慢建立自己的固定節奏、記錄方式與修正邏輯。\n          </p>\n\n          <div class=\"mx-callout\">\n            <div class=\"mx-callout-title\">適合這樣的你</div>\n            <p style=\"margin-bottom:0;\">\n              如果你已經不是「試試看」而已，而是真的準備把手沖變成穩定習慣，那麼 <span class=\"mx-highlight\">M2 PRO＋練功包</span> 會比只買豆子更完整。\n            </p>\n          </div>\n        </section>\n\n        <section id=\"mx-faq\">\n          <h2>常見問題 FAQ</h2>\n          <div class=\"mx-faq\">\n            <details>\n              <summary>手沖咖啡初學者第一包豆該怎麼選？</summary>\n              <div class=\"mx-faq-content\">\n                如果你還不確定自己偏好果酸、花香，還是堅果巧克力調，第一包豆最重要的不是選最熱門，而是選一個能幫你建立比較基準的組合。一次接觸不同產區、處理法與焙度，會比單買一包更容易看見差異。\n              </div>\n            </details>\n\n            <details>\n              <summary>練功包和一般試喝包有什麼差別？</summary>\n              <div class=\"mx-faq-content\">\n                練功包的重點不是單純多口味，而是每款豆子保留第二次修正的機會。第一包先照參數小卡沖，第二包再根據自己的判斷調整研磨度、水量或注水節奏，這樣才能真正完成一次學習循環。\n              </div>\n            </details>\n\n            <details>\n              <summary>每款兩包 18g 的設計，對新手有什麼幫助？</summary>\n              <div class=\"mx-faq-content\">\n                對新手來說，最可惜的不是買錯豆，而是第一杯喝不懂、第二杯又沒機會修正。每款兩包的設計，能讓你先感受，再調整，真正看見前後差異。\n              </div>\n            </details>\n\n            <details>\n              <summary>M2 PRO＋練功包組合適合什麼人？</summary>\n              <div class=\"mx-faq-content\">\n                如果你已經準備開始穩定練習，想把每一次調整都留下比較依據，M2 PRO＋練功包會比只買豆子更完整。豆子與秤一起到位，會更容易建立固定的沖煮流程。\n              </div>\n            </details>\n\n            <details>\n              <summary>如果我本身比較怕酸，應該先從哪類豆子開始？</summary>\n              <div class=\"mx-faq-content\">\n                建議可以先從中焙到中深焙開始，例如偏堅果、奶油、黑巧克力調性的豆子，通常會更容易理解，也比較能建立手沖也能順口好喝的信心。等穩定度提升後，再往淺焙果香型豆子前進。\n              </div>\n            </details>\n          </div>\n        </section>\n\n        <section class=\"mx-cta-final\">\n          <h2>結論：對新手來說，練功包真正賣的是「修正機會」</h2>\n          <p>\n            很多咖啡豆商品都會講產區、講處理法、講風味，但對手沖咖啡初學者來說，最關鍵的問題其實更簡單：<strong>我有沒有第二次機會，把第一杯的問題修回來？</strong>\n          </p>\n          <p>\n            如果你想從一套更有方法的練習開始，而不是只是隨便買一包豆試試看，先從沐萃手沖咖啡豆修正練功包開始；如果你已經準備把每一次調整都留下比較依據，M2 PRO＋練功包組合會更完整。\n          </p>\n          <div class=\"mx-cta-actions\">\n            <a class=\"mx-btn\" href=\"https://www.matrix.com.tw/products/%E6%B2%90%E8%90%83%E5%92%96%E5%95%A1-%E6%B2%90%E8%90%83%E6%89%8B%E6%B2%96%E5%92%96%E5%95%A1%E8%B1%86%E4%BF%AE%E6%AD%A3%E7%B7%B4%E5%8A%9F%E5%8C%858%E6%AC%BE%E9%A2%A8\" target=\"_blank\" rel=\"noopener\">立即選購練功包</a>\n            <a class=\"mx-btn mx-btn-secondary\" href=\"https://www.matrix.com.tw/products/matrix-x%E6%B2%90%E8%90%83%E5%92%96%E5%95%A1-m2-pro\" target=\"_blank\" rel=\"noopener\">查看 M2 PRO＋練功包</a>\n          </div>\n        </section>\n      </main>\n    </div>\n\n    <script>\n      (function () {\n        var root = document.querySelector('.mx-article-coffeeguide');\n        if (!root) return;\n\n        var fab = root.querySelector('#mxTocFab');\n        var drawer = root.querySelector('#mxTocDrawer');\n        var overlay = root.querySelector('#mxTocOverlay');\n        var closeBtn = root.querySelector('#mxTocClose');\n        var drawerLinks = drawer ? drawer.querySelectorAll('a[href^=\"#\"]') : [];\n        var tocLinks = root.querySelectorAll('.mx-toc a[href^=\"#\"]');\n        var allLinks = root.querySelectorAll('a[href^=\"#\"]');\n        var sections = [];\n\n        root.querySelectorAll('section[id]').forEach(function (section) {\n          sections.push(section);\n        });\n\n        function openDrawer() {\n          if (!drawer) return;\n          drawer.classList.add('is-open');\n          drawer.setAttribute('aria-hidden', 'false');\n          document.body.style.overflow = 'hidden';\n        }\n\n        function closeDrawer() {\n          if (!drawer) return;\n          drawer.classList.remove('is-open');\n          drawer.setAttribute('aria-hidden', 'true');\n          document.body.style.overflow = '';\n        }\n\n        if (fab) fab.addEventListener('click', openDrawer);\n        if (overlay) overlay.addEventListener('click', closeDrawer);\n        if (closeBtn) closeBtn.addEventListener('click', closeDrawer);\n\n        drawerLinks.forEach(function (link) {\n          link.addEventListener('click', function () {\n            closeDrawer();\n          });\n        });\n\n        function setActiveLink() {\n          var scrollY = window.scrollY + 140;\n          var currentId = '';\n\n          sections.forEach(function (section) {\n            if (section.offsetTop <= scrollY) {\n              currentId = section.id;\n            }\n          });\n\n          tocLinks.forEach(function (link) {\n            var isActive = link.getAttribute('href') === '#' + currentId;\n            link.classList.toggle('mx-active', isActive);\n          });\n        }\n\n        allLinks.forEach(function (link) {\n          link.addEventListener('click', function (e) {\n            var targetId = link.getAttribute('href');\n            if (!targetId || targetId.charAt(0) !== '#') return;\n            var target = root.querySelector(targetId);\n            if (!target) return;\n            e.preventDefault();\n            window.scrollTo({\n              top: target.getBoundingClientRect().top + window.pageYOffset - 96,\n              behavior: 'smooth'\n            });\n          });\n        });\n\n        window.addEventListener('scroll', setActiveLink, { passive: true });\n        setActiveLink();\n      })();\n    </script>\n  </article>",
