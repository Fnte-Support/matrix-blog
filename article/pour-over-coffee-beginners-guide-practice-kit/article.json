 }\n\n    .mx-article-coffeeguide .mx-bean-card {\n      background: var(--mx-card);\n      border: 1px solid var(--mx-line);\n      border-radius: 22px;\n      padding: 22px 20px;\n      box-shadow: 0 12px 28px rgba(36, 22, 14, 0.05);\n    }\n\n    .mx-article-coffeeguide .mx-bean-card h3 {\n      margin-bottom: 8px;\n      font-size: 22px;\n    }\n\n    .mx-article-coffeeguide .mx-chip-row {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 8px;\n      margin-bottom: 12px;\n    }\n\n    .mx-article-coffeeguide .mx-chip {\n      display: inline-flex;\n      align-items: center;\n      gap: 6px;\n      padding: 6px 10px;\n      border-radius: 999px;\n      background: var(--mx-soft);\n      border: 1px solid var(--mx-line);\n      font-size: 12px;\n      color: var(--mx-muted);\n    }\n\n    .mx-article-coffeeguide .mx-quote {\n      margin: 34px 0;\n      padding: 26px 26px 26px 28px;\n      border-left: 5px solid var(--mx-accent);\n      background: linear-gradient(180deg, #fffdfa 0%, #f8f2ea 100%);\n      border-radius: 18px;\n      font-family: var(--mx-serif);\n      font-size: 21px;\n      color: var(--mx-deep);\n      line-height: 1.7;\n    }\n\n    .mx-article-coffeeguide .mx-steps {\n      display: grid;\n      gap: 14px;\n      margin: 28px 0;\n    }\n\n    .mx-article-coffeeguide .mx-step {\n      display: grid;\n      grid-template-columns: 54px 1fr;\n      gap: 16px;\n      align-items: start;\n      background: var(--mx-card);\n      border: 1px solid var(--mx-line);\n      border-radius: 20px;\n      padding: 18px;\n    }\n\n    .mx-article-coffeeguide .mx-step-no {\n      width: 54px;\n      height: 54px;\n      border-radius: 50%;\n      background: var(--mx-soft);\n      color: var(--mx-accent);\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      font-family: var(--mx-serif);\n      font-size: 22px;\n      font-weight: 700;\n    }\n\n    .mx-article-coffeeguide .mx-product-rail {\n      display: grid;\n 