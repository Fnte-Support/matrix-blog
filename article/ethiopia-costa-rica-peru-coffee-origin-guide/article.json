g) 0;\n        padding-bottom: var(--spacing-md);\n        border-bottom: 3px solid var(--color-accent);\n    }\n    \n    .coffee-article-wrapper h3 {\n        font-family: var(--font-serif);\n        font-size: clamp(1.1rem, 2vw, 1.4rem);\n        font-weight: 600;\n        line-height: 1.4;\n        color: var(--color-primary);\n        margin: var(--spacing-lg) 0 var(--spacing-md) 0;\n    }\n    \n    .coffee-article-wrapper h4 {\n        font-family: var(--font-sans);\n        font-size: 0.95rem;\n        font-weight: 600;\n        letter-spacing: 0.05em;\n        text-transform: uppercase;\n        color: var(--color-accent);\n        margin: var(--spacing-md) 0 var(--spacing-sm) 0;\n    }\n    \n    .coffee-article-wrapper p {\n        margin: 0 0 var(--spacing-md) 0;\n        color: var(--color-neutral-700);\n        line-height: 1.75;\n    }\n    \n    .coffee-article-wrapper strong {\n        font-weight: 600;\n        color: var(--color-accent);\n    }\n    \n    .coffee-article-wrapper em {\n        font-style: italic;\n        color: var(--color-primary);\n    }\n    \n    .coffee-article-wrapper a {\n        color: var(--color-accent);\n        text-decoration: none;\n        font-weight: 500;\n        transition: color 0.3s ease;\n    }\n    \n    .coffee-article-wrapper a:hover {\n        color: var(--color-primary);\n        text-decoration: underline;\n    }\n    \n    /* ===== 導語區塊 ===== */\n    .coffee-article-intro {\n        background: linear-gradient(135deg, #faf8f4 0%, #f5f2ed 100%);\n        border-left: 5px solid var(--color-accent);\n        border-radius: 8px;\n        padding: var(--spacing-lg);\n        margin: var(--spacing-xl) 0;\n        position: relative;\n    }\n    \n    .coffee-article-intro p {\n        margin-bottom: var(--spacing-sm);\n    }\n    \n    .coffee-article-intro p:last-child {\n        margin-bottom: 0;\n    }\n    \n    .coffee-article-intro strong {\n        font-weight: 600;\n        color: var(--color-accent);\n    }\n    \n    /* ===== 數值清單 ===== */\n    .coffee-value-list {\n        list-style: none;\n        margin: var(--spacing-lg) 0;\n        padding: 0;\n    }\n    \n    .coffee-value-list li {\n        padding: var(--spacing-sm) 0 var(--spacing-sm) var(--spacing-lg);\n        position: relative;\n        color: var(--color-neutral-700);\n        line-height: 1.75;\n    }\n    \n    .coffee-value-list li:before {\n        content: \"✓\";\n        position: absolute;\n        left: 0;\n        color: var(--color-success);\n        font-weight: bold;\n        font-size: 1.1rem;\n    }\n    \n    /* ===== 清單 ===== */\n    .coffee-article-wrapper ul,\n    .coffee-article-wrapper ol {\n        margin: 0 0 var(--spacing-md) var(--spacing-lg);\n        padding: 0;\n    }\n    \n    .coffee-article-wrapper li {\n        margin-bottom: var(--spacing-sm);\n        color: var(--color-neutral-700);\n        line-height: 1.75;\n    }\n    \n    .coffee-article-wrapper ul li:marker {\n        color: var(--color-accent);\n    }\n    \n    /* ===== 色塊 ===== */\n    .coffee-highlight-box,\n    .coffee-success-box {\n        border-left: 5px solid;\n        border-radius: 8px;\n        padding: var(--spacing-lg);\n        margin: var(--spacing-lg) 0;\n    }\n    \n    .coffee-highlight-box {\n        background-color: #fffbf0;\n        border-left-color: var(--color-warning);\n    }\n    \n    .coffee-success-box {\n        background-color: #f0f8f5;\n        border-left-color: var(--color-success);\n    }\n    \n    .coffee-highlight-box h4,\n    .coffee-success-box h4 {\n        margin-top: 0;\n    }\n    \n    .coffee-highlight-box p,\n    .coffee-success-box p {\n        margin-bottom: var(--spacing-sm);\n    }\n    \n    .coffee-highlight-box p:last-child,\n    .coffee-success-box p:last-child {\n        margin-bottom: 0;\n    }\n    \n    /* ===== 表格 ===== */\n    .coffee-article-wrapper table {\n        width: 100%;\n        border-collapse: collapse;\n        margin: var(--spacing-lg) 0;\n        border-radius: 8px;\n        overflow: hidden;\n        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n    }\n    \n    .coffee-article-wrapper thead {\n        background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 100%);\n        color: var(--color-white);\n    }\n    \n    .coffee-article-wrapper th {\n        padding: var(--spacing-md);\n        text-align: left;\n        font-family: var(--font-sans);\n        font-weight: 600;\n        letter-spacing: 0.5px;\n        border: none;\n    }\n    \n    .coffee-article-wrapper td {\n        padding: var(--spacing-md);\n        border-bottom: 1px solid var(--color-neutral-100);\n        color: var(--color-neutral-700);\n        line-height: 1.75;\n    }\n    \n    .coffee-article-wrapper tbody tr:hover {\n        background-color: #faf8f4;\n        transition: background-color 0.3s ease;\n    }\n    \n    /* ===== 圖片預留位置 ===== */\n    .coffee-image-placeholder {\n        background: linear-gradient(135deg, #f8f6f1 0%, #f0ede8 100%);\n        border: 2px dashed rgba(193, 122, 84, 0.3);\n        border-radius: 8px;\n        padding: var(--spacing-xl);\n        text-align: center;\n        margin: var(--spacing-lg) 0;\n        min-height: 300px;\n        display: flex;\n        align-items: center;\n        justify-content: center;\n        font-size: 0.9rem;\n        color: var(--color-neutral-600);\n    }\n    \n    .coffee-image-placeholder.tall {\n        min-height: 500px;\n    }\n    \n    .coffee-image-placeholder code {\n        background-color: #2c1810;\n        color: #e8c5a8;\n        padding: var(--spacing-sm);\n        border-radius: 4px;\n        display: block;\n        margin-top: var(--spacing-md);\n        font-family: 'Monaco', monospace;\n        font-size: 0.8rem;\n        overflow-x: auto;\n    }\n    \n    .coffee-image-caption {\n        font-size: 0.85rem;\n        color: var(--color-neutral-600);\n        margin-top: var(--spacing-sm);\n        text-align: center;\n        font-style: italic;\n    }\n    \n    /* ===== FAQ 折疊 ===== */\n    .coffee-faq-item {\n        border: 1px solid var(--color-neutral-100);\n        border-radius: 8px;\n        margin-bottom: var(--spacing-md);\n        overflow: hidden;\n        transition: box-shadow 0.3s ease;\n    }\n    \n    .coffee-faq-item:hover {\n        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n    }\n    \n    .coffee-faq-question {\n        display: flex;\n        justify-content: space-between;\n        align-items: center;\n        padding: var(--spacing-lg);\n        background-color: #faf8f4;\n        cursor: pointer;\n        user-select: none;\n        font-weight: 600;\n        color: var(--color-primary);\n        transition: background-color 0.3s ease;\n    }\n    \n    .coffee-faq-question:hover {\n        background-color: #f5f2ed;\n    }\n    \n    .coffee-faq-toggle {\n        display: inline-flex;\n        align-items: center;\n        justify-content: center;\n        width: 24px;\n        height: 24px;\n        border-radius: 50%;\n        background-color: var(--color-accent);\n        color: var(--color-white);\n        font-size: 0.8rem;\n        flex-shrink: 0;\n        transition: transform 0.3s ease;\n    }\n    \n    .coffee-faq-item.open .coffee-faq-toggle {\n        transform: rotate(180deg);\n    }\n    \n    .coffee-faq-answer {\n        display: none;\n        padding: var(--spacing-lg);\n        background-color: var(--color-white);\n        border-top: 1px solid var(--color-neutral-100);\n        color: var(--color-neutral-700);\n        line-height: 1.75;\n    }\n    \n    .coffee-faq-item.open .coffee-faq-answer {\n        display: block;\n    }\n    \n    /* ===== 分隔線 ===== */\n    .coffee-divider {\n        height: 2px;\n        background: linear-gradient(90deg, transparent, var(--color-accent), transparent);\n        margin: var(--spacing-2xl) 0;\n        border: none;\n    }\n    \n    /* ===== CTA區塊 ===== */\n    .coffee-cta-section {\n        background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 100%);\n        color: var(--color-white);\n        padding: var(--spacing-xl);\n        border-radius: 8px;\n        margin: var(--spacing-2xl) 0;\n        text-align: center;\n    }\n    \n    .coffee-cta-section h3 {\n        color: var(--color-white);\n        border-bottom: none;\n    }\n    \n    .coffee-cta-section p {\n        color: rgba(255, 255, 255, 0.95);\n    }\n    \n    .coffee-cta-button {\n        display: inline-block;\n        background-color: var(--color-accent);\n        color: var(--color-white);\n        padding: var(--spacing-md) var(--spacing-lg);\n        border-radius: 6px;\n        font-weight: 600;\n        text-decoration: none;\n        transition: all 0.3s ease;\n        margin: var(--spacing-sm);\n        border: 2px solid var(--color-accent);\n        cursor: pointer;\n        font-size: 0.95rem;\n        text-transform: uppercase;\n        letter-spacing: 0.05em;\n    }\n    \n    .coffee-cta-button:hover {\n        background-color: var(--color-accent-light);\n        color: var(--color-primary-dark);\n        transform: translateY(-2px);\n    }\n    \n    /* ===== 響應式設計 ===== */\n    @media (max-width: 768px) {\n        .coffee-article-wrapper {\n            padding: var(--spacing-lg) var(--spacing-md);\n        }\n        \n        .coffee-article-wrapper h1 {\n            font-size: 1.6rem;\n        }\n        \n        .coffee-article-wrapper h2 {\n            font-size: 1.3rem;\n            margin-top: var(--spacing-lg);\n        }\n        \n        .coffee-article-wrapper table {\n            font-size: 0.9rem;\n        }\n        \n        .coffee-article-wrapper th,\n        .coffee-article-wrapper td {\n            padding: var(--spacing-sm);\n        }\n        \n        .coffee-image-placeholder {\n            min-height: 200px;\n        }\n        \n        .coffee-image-placeholder.tall {\n            min-height: 300px;\n        }\n        \n        .coffee-cta-section {\n            padding: var(--spacing-lg);\n        }\n    }\n    \n    @media (max-width: 480px) {\n        .coffee-article-wrapper {\n            padding: var(--spacing-md);\n        }\n        \n        .coffee-article-wrapper h1 {\n            font-size: 1.3rem;\n        }\n        \n        .coffee-article-wrapper h2 {\n            font-size: 1.1rem;\n        }\n        \n        .coffee-article-wrapper h3 {\n            font-size: 1rem;\n        }\n        \n        .coffee-intro-box {\n            padding: var(--spacing-md);\n        }\n        \n        .coffee-article-wrapper ul,\n        .coffee-article-wrapper ol {\n            margin-left: var(--spacing-md);\n        }\n        \n        .coffee-article-wrapper table {\n            font-size: 0.8rem;\n            display: block;\n            overflow-x: auto;\n        }\n        \n        .coffee-cta-button {\n            display: block;\n            width: 100%;\n            margin: var(--spacing-sm) 0;\n        }\n    }\n</style>\n\n<div class=\"coffee-article-wrapper\">\n    <!-- 文章標題 -->\n    <h1>衣索比亞 vs 哥斯大黎加 vs 秘魯：咖啡豆產地特色對比指南</h1>\n    \n    <!-- 導語區塊 -->\n    <div class=\"coffee-article-intro\">\n        <p>站在咖啡館前，看著菜單上密密麻麻的<strong>衣索比亞、哥斯大黎加、秘魯</strong>等產地名稱，卻不知道該如何選擇？</p>\n        <p>根據統計，全球咖啡愛好者每年消費超過2億杯咖啡，而<strong>咖啡豆的產地特色</strong>往往決定了一杯咖啡的風味靈魂。</p>\n        <p><em>這篇文章將改變你的咖啡選購方式。</em></p>\n    </div>\n    \n    <p style=\"margin-top: var(--spacing-lg); font-weight: 500; color: var(--color-primary);\">讀完後，你將能夠：</p>\n    <ul class=\"coffee-value-list\">\n        <li>準確分辨五大產地咖啡的風味特徵</li>\n        <li>根據口味偏好與使用場景精準選購</li>\n        <li>理解產地特色與價格的真實關係</li>\n        <li>用正確的方式品鑑每一款豆子</li>\n        <li>迅速升級為具有品鑑眼光的消費者</li>\n    </ul>\n    \n    <hr class=\"coffee-divider\">\n    \n    <!-- 衣索比亞 -->\n    <section>\n        <h2>一、衣索比亞咖啡：咖啡的起源地</h2>\n        \n        <h3>地理位置與氣候特點</h3>\n        <p>衣索比亞是<strong>咖啡的故鄉</strong>，也是全球最古老的咖啡生產國。位於非洲東北部的高原地帶，平均海拔1,500-2,200公尺，得天獨厚的地理優勢造就了獨一無二的咖啡風味。</p>\n        \n        <div class=\"coffee-image-placeholder tall\">\n            預留衣索比亞地理位置圖\n            <code>&lt;img src=\"YOUR_IMAGE_URL\" alt=\"衣索比亞咖啡產區地圖\"&gt;</code>\n        </div>\n        <div class=\"coffee-image-caption\">圖 1：衣索比亞咖啡產區地圖</div>\n        \n        <h3>咖啡豆特性與風味傾向</h3>\n        <p>衣索比亞咖啡是全球風味最獨特、也最具個性的咖啡豆之一。其主要特徵包括：</p>\n        <ul>\n            <li><strong>果香突出</strong>：天然花香與莓果香氣是衣索比亞咖啡的招牌風味</li>\n            <li><strong>酸度明亮</strong>：高海拔賦予其活潑的果酸，清爽而不刺激</li>\n            <li><strong>茶感明顯</strong>：口感圓潤，入喉後帶有淡淡的茶香，回甘綿長</li>\n            <li><strong>複雜度高</strong>：單一豆子就能展現多層次風味變化</li>\n        </ul>\n        \n        <div class=\"coffee-highlight-box\">\n            <h4>✨ 推薦指數：⭐⭐⭐⭐</h4>\n            <p>衣索比亞咖啡適合用於品鑑練習或特殊場合享受。首次購買建議選擇<strong>耶加雪菲或古吉產區</strong>。預算若有限，可透過沐晴咖啡的練功包先體驗。</p>\n        </div>\n    </section>\n    \n    <hr class=\"coffee-divider\">\n    \n    <!-- 哥斯大黎加 -->\n    <section>\n        <h2>二、哥斯大黎加咖啡：中美洲的甜蜜瑰寶</h2>\n        \n        <h3>地理位置與氣候特點</h3>\n        <p>哥斯大黎加位於中美洲，介於太平洋與加勒比海之間。國內地形多為山區高地，主要咖啡產區集中在中央山谷、塔拉蘇和西部山谷等地。</p>\n        \n        <div class=\"coffee-image-placeholder tall\">\n            預留哥斯大黎加產區圖\n            <code>&lt;img src=\"YOUR_IMAGE_URL\" alt=\"哥斯大黎加咖啡產區\"&gt;</code>\n        </div>\n        <div class=\"coffee-image-caption\">圖 2：哥斯大黎加主要咖啡產區分佈</div>\n        \n        <h3>咖啡豆特性與風味傾向</h3>\n        <p>哥斯大黎加咖啡以<strong>甜感突出、均衡柔和</strong>著稱，是中美洲咖啡的典型代表：</p>\n        <ul>\n            <li><strong>天然甜感</strong>：焦糖、巧克力、堅果香是其標誌風味</li>\n            <li><strong>酸度溫和</strong>：中等酸度，不搶風頭但貢獻清爽度</li>\n            <li><strong>口感厚實</strong>：油脂感明顯，入喉柔順圓潤</li>\n            <li><strong>穩定性高</strong>：不同批次品質差異小，買到地雷的機率最低</li>\n        </ul>\n        \n        <div class=\"coffee-success-box\">\n            <h4>🎯 新手首選</h4>\n            <p>哥斯大黎加是最推薦新手購買的產地。寬容度最高，適合各種沖泡方式，價格合理，品質穩定。</p>\n        </div>\n    </section>\n    \n    <hr class=\"coffee-divider\">\n    \n    <!-- 秘魯 -->\n    <section>\n        <h2>三、秘魯咖啡：安地斯山脈的隱藏寶藏</h2>\n        \n        <h3>地理位置與氣候特點</h3>\n        <p>秘魯位於南美洲西部，安地斯山脈縱貫全境。秘魯的主要咖啡產區分佈在叢林邊界地帶，平均海拔1,200-1,800公尺，部分高端產區甚至超過2,000公尺。</p>\n        \n        <h3>咖啡豆特性與風味傾向</h3>\n        <p>秘魯咖啡是<strong>被低估的瑰寶</strong>，具備以下特徵：</p>\n        <ul>\n            <li><strong>多層次感</strong>：堅果、巧克力、香料與微妙的果香交織</li>\n            <li><strong>醇厚口感</strong>：油脂感豐富，入喉厚重飽滿</li>\n            <li><strong>平衡度高</strong>：酸度、甜度、苦度搭配得當，不失個性又容易親近</li>\n            <li><strong>性價比高</strong>：常比同級哥倫比亞豆便宜15-25%</li>\n        </ul>\n        \n        <div class=\"coffee-image-placeholder\">\n            預留秘魯咖啡風味圖\n            <code>&lt;img src=\"YOUR_IMAGE_URL\" alt=\"秘魯咖啡特徵風味分析\"&gt;</code>\n        </div>\n        <div class=\"coffee-image-caption\">圖 3：秘魯咖啡特徵風味分析</div>\n    </section>\n    \n    <hr class=\"coffee-divider\">\n    \n    <!-- 哥倫比亞 -->\n    <section>\n        <h2>四、哥倫比亞咖啡：風味與產量的完美平衡</h2>\n        \n        <h3>地理位置與氣候特點</h3>\n        <p>哥倫比亞位於南美洲西北部，安地斯山脈的三條縱谷提供了多樣化的微氣候環境。咖啡產區海拔範圍800-2,200公尺，依據緯度與海拔的不同組合產出差異化風味。</p>\n        \n        <h3>咖啡豆特性與風味傾向</h3>\n        <p>哥倫比亞咖啡被稱為<strong>「全能型咖啡豆」</strong>，以下特點備受推崇：</p>\n        <ul>\n            <li><strong>均衡的風味檔案</strong>：中等酸度、中等醇厚度、適度甜感的完美組合</li>\n            <li><strong>堅果與可可香</strong>：焙度越深，巧克力與烤堅果香越濃郁</li>\n            <li><strong>果香與花香</strong>：高海拔產區帶有草莓、黑醋栗或茉莉花香</li>\n            <li><strong>通用性最強</strong>：最適合作為日常咖啡享用</li>\n        </ul>\n    </section>\n    \n    <hr class=\"coffee-divider\">\n    \n    <!-- 巴西 -->\n    <section>\n        <h2>五、巴西咖啡：產量與甜感的代名詞</h2>\n        \n        <h3>地理位置與氣候特點</h3>\n        <p>巴西是全球最大咖啡生產國，全球咖啡供應量的三分之一來自巴西。主要咖啡產區位於巴西東南部，平均海拔600-1,200公尺。</p>\n        \n        <h3>咖啡豆特性與風味傾向</h3>\n        <p>巴西咖啡以<strong>極高的甜感</strong>與<strong>低酸度</strong>著稱，是甜味咖啡愛好者的天堂：</p>\n        <ul>\n            <li><strong>天然甜感最高</strong>：焦糖、巧克力、葡萄乾、蜜糖香氣層出不窮</li>\n            <li><strong>低酸度友善</strong>：胃酸敏感者可安心享受</li>\n            <li><strong>厚重醇厚感</strong>：油脂豐富，口感濃郁</li>\n            <li><strong>烘焙寬容度高</strong>：從淺焙到深焙都能展現甜感，不易變苦</li>\n        </ul>\n        \n        <div class=\"coffee-highlight-box\">\n            <h4>💰 預算優先</h4>\n            <p>巴西咖啡產量大、價格親民，是預算有限但不想妥協品質的首選。預算300元/100g以下就能買到優質巴西豆。</p>\n        </div>\n    </section>\n    \n    <hr class=\"coffee-divider\">\n    \n    <!-- 產地對比表 -->\n    <section>\n        <h2>六、五大咖啡產地一覽表</h2>\n        \n        <table>\n            <thead>\n                <tr>\n                    <th>產地</th>\n                    <th>海拔</th>\n                    <th>主要特色</th>\n                    <th>推薦焙度</th>\n                    <th>新手友善度</th>\n                </tr>\n            </thead>\n            <tbody>\n                <tr>\n                    <td><strong>衣索比亞</strong></td>\n                    <td>1,500-2,200m</td>\n                    <td>花果香、明亮酸度、茶感</td>\n                    <td>淺-中焙</td>\n                    <td>⭐⭐</td>\n                </tr>\n                <tr>\n                    <td><strong>哥斯大黎加</strong></td>\n                    <td>1,000-1,900m</td>\n                    <td>焦糖甜、均衡感、穩定性</td>\n                    <td>中-深焙</td>\n                    <td>⭐⭐⭐⭐⭐</td>\n                </tr>\n                <tr>\n                    <td><strong>秘魯</strong></td>\n                    <td>1,200-1,800m</td>\n                    <td>堅果、巧克力、多層次感</td>\n                    <td>中焙</td>\n                    <td>⭐⭐⭐⭐</td>\n                </tr>\n                <tr>\n                    <td><strong>哥倫比亞</strong></td>\n                    <td>800-2,200m</td>\n                    <td>均衡檔案、堅果香、通用性</td>\n                    <td>中焙</td>\n                    <td>⭐⭐⭐⭐⭐</td>\n                </tr>\n                <tr>\n                    <td><strong>巴西</strong></td>\n                    <td>600-1,200m</td>\n                    <td>極甜感、低酸度、濃郁</td>\n                    <td>深-極深焙</td>\n                    <td>⭐⭐⭐⭐⭐</td>\n                </tr>\n            </tbody>\n        </table>\n    </section>\n    \n    <hr class=\"coffee-divider\">\n    \n    <!-- 購買指南 -->\n    <section>\n        <h2>七、咖啡豆購買決策指南</h2>\n        \n        <h3>根據口味偏好選擇</h3>\n        <ul>\n            <li><strong>喜歡花果香、高酸度</strong> → 衣索比亞</li>\n            <li><strong>喜歡焦糖甜、均衡感</strong> → 哥斯大黎加</li>\n            <li><strong>喜歡堅果巧克力、多層次</strong> → 秘魯</li>\n            <li><strong>喜歡全能型、日常搭配</strong> → 哥倫比亞</li>\n            <li><strong>喜歡極甜感、低酸度</strong> → 巴西</li>\n        </ul>\n        \n        <h3>根據使用場景選擇</h3>\n        <table>\n            <thead>\n                <tr>\n                    <th>使用場景</th>\n                    <th>推薦產地</th>\n                    <th>原因</th>\n                </tr>\n            </thead>\n            <tbody>\n                <tr>\n                    <td><strong>早晨提神</strong></td>\n                    <td>衣索比亞、哥倫比亞</td>\n                    <td>酸度明亮、層次豐富，幫助大腦清醒</td>\n                </tr>\n                <tr>\n                    <td><strong>餐後享受</strong></td>\n                    <td>哥斯大黎加、巴西</td>\n                    <td>甜感突出，消解油膩感</td>\n                </tr>\n                <tr>\n                    <td><strong>下午放鬆</strong></td>\n                    <td>秘魯</td>\n                    <td>平衡感強，不會過度刺激</td>\n                </tr>\n                <tr>\n                    <td><strong>晚間社交</strong></td>\n                    <td>哥倫比亞</td>\n                    <td>通用性強，適合與他人分享</td>\n                </tr>\n            </tbody>\n        </table>\n    </section>\n    \n    <hr class=\"coffee-divider\">\n    \n    <!-- 品鑑技巧 -->\n    <section>\n        <h2>八、咖啡豆品鑑的五感體驗</h2>\n        \n        <p>真正的咖啡品鑑不只是品嚐，而是一場全身心的體驗。以下是建議的品鑑流程：</p>\n        \n        <h3>1. 視覺（Visual）</h3>\n        <p>觀察咖啡豆的色澤，了解烘焙程度。不同烘焙度的豆子呈現不同的外觀特徵。</p>\n        <div class=\"coffee-image-placeholder\">\n            預留咖啡豆烘焙度對比圖\n            <code>&lt;img src=\"YOUR_IMAGE_URL\" alt=\"咖啡豆烘焙度對比\"&gt;</code>\n        </div>\n        <div class=\"coffee-image-caption\">圖 4：淺焙、中焙、深焙咖啡豆外觀對比</div>\n        \n        <h3>2. 嗅覺（Aroma）</h3>\n        <p>磨粉後立即聞香，香氣是風味的預告。注意<strong>乾香</strong>（磨粉直後）、<strong>濕香</strong>（熱水注入後）和<strong>尾香</strong>（冷卻後）的變化。</p>\n        \n        <h3>3. 味覺（Taste）</h3>\n        <p>小口品嚐，讓咖啡在舌尖停留數秒。感受<strong>前段香氣</strong>（初始風味）、<strong>中段風味</strong>（核心特徵）和<strong>尾韻</strong>（餘韻）。</p>\n        \n        <h3>4. 口感（Mouthfeel）</h3>\n        <p>評估咖啡的質地與觸覺印象：</p>\n        <ul>\n            <li><strong>酸度</strong>：不是壞味道，而是活潑度與複雜度的體現</li>\n            <li><strong>醇厚度（Body）</strong>：油脂與顆粒物帶來的飽滿感</li>\n            <li><strong>甜感</strong>：來自咖啡豆本身的天然糖分</li>\n        </ul>\n        \n        <h3>5. 整體評分（Overall）</h3>\n        <p>綜合上述四項，給予總體評分。建議記錄方式：<strong>豆子名稱 | 香氣(★★★) | 甜度(★★★) | 酸度(★★★) | 複雜度(★★★) | 總評(★★★★)</strong></p>\n    </section>\n    \n    <hr class=\"coffee-divider\">\n    \n    <!-- FAQ -->\n    <section>\n        <h2>九、購買前的常見問題</h2>\n        \n        <div class=\"coffee-faq-item\">\n            <div class=\"coffee-faq-question\">\n                <span>Q：我怕買錯豆子怎麼辦？</span>\n                <div class=\"coffee-faq-toggle\">▼</div>\n            </div>\n            <div class=\"coffee-faq-answer\">\n                <p>這是最常見的購買猶豫。<strong>解決方案很簡單：先買練功包。</strong> 1,500元體驗8款豆子，比1,500元買一款不喜歡的豆子聰明多了。而且練功包會告訴你到底喜歡什麼，下一次購買就不會再錯。</p>\n            </div>\n        </div>\n        \n        <div class=\"coffee-faq-item\">\n            <div class=\"coffee-faq-question\">\n                <span>Q：練功包值得買嗎？會不會是營銷噱頭？</span>\n                <div class=\"coffee-faq-toggle\">▼</div>\n            </div>\n            <div class=\"coffee-faq-answer\">\n                <p>完全值得。計算一下：同樣8款豆子分別購買要2,500-3,500元，練功包只要1,500元。而且官方已經幫你篩選代表性豆子，省時省力。唯一「損失」是豆子用量小（每款25-50g），但這正好適合品鑑練習。</p>\n            </div>\n        </div>\n        \n        <div class=\"coffee-faq-item\">\n            <div class=\"coffee-faq-question\">\n                <span>Q：同一產地的咖啡風味為何會有差異？</span>\n                <div class=\"coffee-faq-answer\">\n            <p>即使同一產地，不同年份、不同海拔、不同處理方法、不同烘焙度都會影響最終風味。這也是咖啡的魅力所在——永遠有新的發現。</p>\n            </div>\n        </div>\n        \n        <div class=\"coffee-faq-item\">\n            <div class=\"coffee-faq-question\">\n                <span>Q：咖啡豆的新鮮度如何判斷？</span>\n                <div class=\"coffee-faq-toggle\">▼</div>\n            </div>\n            <div class=\"coffee-faq-answer\">\n                <p>查看包裝上的<strong>烘焙日期</strong>，最佳賞味期為烘焙後1-4週。過新的豆子（3天內）尚未充分釋放香氣，過舊的豆子（超過3個月）風味會逐漸衰退。</p>\n            </div>\n        </div>\n        \n        <div class=\"coffee-faq-item\">\n            <div class=\"coffee-faq-question\">\n                <span>Q：我看到很多人推薦衣索比亞，我必須喜歡嗎？</span>\n                <div class=\"coffee-faq-toggle\">▼</div>\n            </div>\n            <div class=\"coffee-faq-answer\">\n                <p><strong>完全不是。</strong>咖啡館推薦衣索比亞通常因為利潤高或行銷噱頭。信任你的舌頭，不要被行銷迷惑。如果你發現自己更喜歡巴西的甜感，那就大膽選巴西，沒有「正確答案」。</p>\n            </div>\n        </div>\n    </section>\n    \n    <hr class=\"coffee-divider\">\n    \n    <!-- CTA -->\n    <div class=\"coffee-cta-section\">\n        <h3>準備開始你的咖啡升級之旅？</h3>\n        <p>現在你比90%的咖啡消費者懂得更多。真正的差別，將從你的下一步行動開始。</p>\n        <p><strong>建議購買順序：</strong><br>\n        1️⃣ 這週訂練功包 → 2️⃣ 準備沖泡工具 → 3️⃣ 開始品鑑記錄</p>\n        <a href=\"#\" class=\"coffee-cta-button\">購買沐晴咖啡練功包</a>\n        <a href=\"#\" class=\"coffee-cta-button\">了解咖啡機方案</a>\n    </div>\n</div>\n\n<!-- FAQ 互動功能 -->\n<script>\n(function() {\n    document.addEventListener('DOMContentLoaded', function() {\n        const faqItems = document.querySelectorAll('.coffee-faq-item');\n        \n        faqItems.forEach(item => {\n            const question = item.querySelector('.coffee-faq-question');\n            \n            if (question) {\n                question.addEventListener('click', function() {\n                    item.classList.toggle('open');\n                });\n                \n                // 鍵盤支援\n                question.setAttribute('role', 'button');\n                question.setAttribute('tabindex', '0');\n                question.addEventListener('keydown', function(e) {\n                    if (e.key === 'Enter' || e.key === ' ') {\n                        e.preventDefault();\n                        item.classList.toggle('open');\n                    }\n                });\n            }\n        });\n    });\n})();\n</script>",
