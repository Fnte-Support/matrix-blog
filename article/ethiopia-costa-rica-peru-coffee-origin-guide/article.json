0px;\n            right: 20px;\n            width: 50px;\n            height: 50px;\n            border-radius: 50%;\n            background-color: var(--color-accent);\n            color: var(--color-white);\n            border: none;\n            font-size: 1.2rem;\n            cursor: pointer;\n            z-index: 40;\n            box-shadow: 0 2px 12px rgba(193, 122, 84, 0.3);\n            transition: all 0.3s ease;\n        }\n        \n        .toc-mobile-btn:hover {\n            transform: scale(1.1);\n            box-shadow: 0 4px 16px rgba(193, 122, 84, 0.5);\n        }\n        \n        .toc-mobile-menu {\n            display: none;\n            position: fixed;\n            top: 80px;\n            right: 20px;\n            width: 280px;\n            background-color: var(--color-white);\n            border: 1px solid var(--color-neutral-100);\n            border-radius: 8px;\n            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);\n            max-height: 60vh;\n            overflow-y: auto;\n            padding: var(--spacing-lg);\n            z-index: 45;\n        }\n        \n        .toc-mobile-menu.show {\n            display: block;\n        }\n        \n        \n        /* ===== FAQ 折疊 ===== */\n        .faq-section {\n            margin: var(--spacing-2xl) 0;\n        }\n        \n        .faq-item {\n            border: 1px solid var(--color-neutral-100);\n            border-radius: 8px;\n            margin-bottom: var(--spacing-md);\n            overflow: hidden;\n            transition: box-shadow 0.3s ease;\n        }\n        \n        .faq-item:hover {\n            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);\n        }\n        \n        .faq-question {\n            display: flex;\n            justify-content: space-between;\n            align-items: center;\n            padding: var(--spacing-lg);\n            background-color: #fafafa;\n            cursor: pointer;\n            user-select: none;\n            font-weight: 600;\n            color: var(--color-primary);\n            transition: background-color 0.3s ease;\n        }\n        \n        .faq-question:hover {\n            background-color: #f5f5f5;\n        }\n        \n        .faq-toggle {\n            display: inline-flex;\n            align-items: center;\n            justify-content: center;\n            width: 24px;\n            height: 24px;\n            border-radius: 50%;\n            background-color: var(--color-accent);\n            color: var(--color-white);\n            font-size: 0.8rem;\n            flex-shrink: 0;\n            transition: transform 0.3s ease;\n        }\n        \n        .faq-item.open .faq-toggle {\n            transform: rotate(180deg);\n        }\n        \n        .faq-answer {\n            display: none;\n            padding: var(--spacing-lg);\n            background-color: var(--color-white);\n            border-top: 1px solid var(--color-neutral-100);\n            color: var(--color-neutral-700);\n            line-height: var(--line-height-loose);\n        }\n        \n        .faq-item.open .faq-answer {\n            display: block;\n            animation: slideDown 0.3s ease;\n        }\n        \n        @keyframes slideDown {\n            from {\n                opacity: 0;\n                transform: translateY(-10px);\n            }\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n        \n        /* ===== 分隔線 ===== */\n        .divider {\n            height: 2px;\n            background: linear-gradient(90deg, transparent, var(--color-accent), transparent);\n            margin: var(--spacing-2xl) 0;\n            border: none;\n        }\n        \n        /* ===== 結尾號召 ===== */\n        .cta-section {\n            background: linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 100%);\n            color: var(--color-white);\n            padding: var(--spacing-2xl);\n            border-radius: 12px;\n            margin: var(--spacing-2xl) 0;\n            text-align: center;\n        }\n        \n        .cta-section h3 {\n            color: var(--color-white);\n            border-bottom: none;\n            margin-top: 0;\n        }\n        \n        .cta-button {\n            display: inline-block;\n            background-color: var(--color-accent);\n            color: var(--color-white);\n            padding: var(--spacing-md) var(--spacing-xl);\n            border-radius: 8px;\n            font-weight: 600;\n            transition: all 0.3s ease;\n            margin-top: var(--spacing-md);\n            border: 2px solid var(--color-accent);\n        }\n        \n        .cta-button:hover {\n            background-color: var(--color-accent-light);\n            transform: translateY(-2px);\n            box-shadow: 0 4px 12px rgba(193, 122, 84, 0.3);\n        }\n        \n        /* ===== 響應式設計 ===== */\n        @media (max-width: 1399px) {\n            .toc-wrapper {\n                display: none;\n            }\n            \n            main {\n                padding: var(--spacing-xl) var(--spacing-md);\n            }\n        }\n        \n        @media (max-width: 768px) {\n            h1 {\n                font-size: 1.8rem;\n            }\n            \n            h2 {\n                font-size: 1.4rem;\n                margin-top: var(--spacing-xl);\n            }\n            \n            h3 {\n                font-size: 1.1rem;\n            }\n            \n            main {\n                padding: var(--spacing-lg) var(--spacing-md);\n            }\n            \n            table {\n                font-size: 0.9rem;\n            }\n            \n            th, td {\n                padding: var(--spacing-sm);\n            }\n            \n            .toc-mobile-btn {\n                display: flex;\n                align-items: center;\n                justify-content: center;\n            }\n            \n            .image-placeholder {\n                min-height: 200px;\n            }\n            \n            .image-placeholder.tall {\n                min-height: 300px;\n            }\n            \n            .cta-section {\n                padding: var(--spacing-lg);\n            }\n        }\n        \n        @media (max-width: 480px) {\n            h1 {\n                font-size: 1.4rem;\n            }\n            \n            h2 {\n                font-size: 1.2rem;\n            }\n            \n            h3 {\n                font-size: 1rem;\n            }\n            \n            main {\n                padding: var(--spacing-md) var(--spacing-sm);\n            }\n            \n            .intro-box {\n                padding: var(--spacing-md);\n            }\n            \n            ul, ol {\n                margin-left: var(--spacing-md);\n            }\n            \n            table {\n                font-size: 0.85rem;\n                display: block;\n                overflow-x: auto;\n            }\n        }\n        \n        /* ===== 列印 ===== */\n        @media print {\n            .toc-wrapper,\n            .toc-mobile-btn,\n            header {\n                display: none;\n            }\n            \n            main {\n                margin-left: 0;\n            }\n            \n            a {\n                color: var(--color-primary);\n            }\n        }\n    </style>\n\n  \n    \n    <!-- TOC 固定側邊欄（桌面版） -->\n    <aside class=\"toc-wrapper\">\n        <div class=\"toc-title\">目錄</div>\n        <ul class=\"toc-list\">\n            <li><a href=\"#intro\">前言</a></li>\n            <li><a href=\"#ethiopia\">衣索比亞</a></li>\n            <li><a href=\"#costarica\">哥斯大黎加</a></li>\n            <li><a href=\"#peru\">秘魯</a></li>\n            <li><a href=\"#colombia\">哥倫比亞</a></li>\n            <li><a href=\"#brazil\">巴西</a></li>\n            <li><a href=\"#comparison\">產地對比</a></li>\n            <li><a href=\"#purchase\">購買指南</a></li>\n            <li><a href=\"#tasting\">品鑑技巧</a></li>\n            <li><a href=\"#faq\">常見問題</a></li>\n        </ul>\n    </aside>\n    \n    <!-- TOC 行動按鈕（手機版） -->\n    <button class=\"toc-mobile-btn\" id=\"tocToggle\">☰</button>\n    <div class=\"toc-mobile-menu\" id=\"tocMenu\">\n        <div class=\"toc-title\">目錄</div>\n        <ul class=\"toc-list\">\n            <li><a href=\"#intro\">前言</a></li>\n            <li><a href=\"#ethiopia\">衣索比亞</a></li>\n            <li><a href=\"#costarica\">哥斯大黎加</a></li>\n            <li><a href=\"#peru\">秘魯</a></li>\n            <li><a href=\"#colombia\">哥倫比亞</a></li>\n            <li><a href=\"#brazil\">巴西</a></li>\n            <li><a href=\"#comparison\">產地對比</a></li>\n            <li><a href=\"#purchase\">購買指南</a></li>\n            <li><a href=\"#tasting\">品鑑技巧</a></li>\n            <li><a href=\"#faq\">常見問題</a></li>\n        </ul>\n    </div>\n    \n    <!-- 主要內容 -->\n    <main>\n        <article>\n            <div class=\"article-content\">\n                <!-- 文章標題 -->\n                <h1>衣索比亞vs哥斯大黎加vs秘魯：咖啡豆產地特色對比指南</h1>\n                \n                <!-- 導語 -->\n                <section id=\"intro\">\n                    <div class=\"intro-box\">\n                        <p>站在咖啡館前，看著菜單上密密麻麻的<strong>衣索比亞、哥斯大黎加、秘魯</strong>等產地名稱，卻不知道該如何選擇？</p>\n                        <p>根據統計，全球咖啡愛好者每年消費超過2億杯咖啡，而<strong>咖啡豆的產地特色</strong>往往決定了一杯咖啡的風味靈魂。</p>\n                        <p><em>這篇文章將改變你的咖啡選購方式。</em></p>\n                    </div>\n                    \n                    <p style=\"margin-top: var(--spacing-lg); font-weight: 500; color: var(--color-primary);\">讀完後，你將能夠：</p>\n                    <ul class=\"value-list\">\n                        <li>準確分辨五大產地咖啡的風味特徵</li>\n                        <li>根據口味偏好與使用場景精準選購</li>\n                        <li>理解產地特色與價格的真實關係</li>\n                        <li>用正確的方式品鑑每一款豆子</li>\n                        <li>迅速升級為具有品鑑眼光的消費者</li>\n                    </ul>\n                </section>\n                \n                <hr class=\"divider\">\n                \n                <!-- 衣索比亞 -->\n                <section id=\"ethiopia\">\n                    <h2>一、衣索比亞咖啡：咖啡的起源地</h2>\n                    \n                    <h3>地理位置與氣候特點</h3>\n                    <p>衣索比亞是<strong>咖啡的故鄉</strong>，也是全球最古老的咖啡生產國。位於非洲東北部的高原地帶，平均海拔1,500-2,200公尺，得天獨厚的地理優勢造就了獨一無二的咖啡風味。</p>\n                    \n                    <div class=\"image-placeholder tall\">\n                        <img src=\"https://img.1shop.tw/e2mJZnvrG0rg7v5AKPba5qkd/dqpOVABK324Bmv7qNrkRwEv7/original.png\" alt=\"衣索比亞地理位置地圖\">\n                    </div>\n                    <div class=\"image-caption\">圖 1-1：衣索比亞咖啡產區地圖</div>\n                    \n                    <h3>咖啡豆特性與風味傾向</h3>\n                    <p>衣索比亞咖啡是全球風味最獨特、也最具個性的咖啡豆之一。其主要特徵包括：</p>\n                    <ul>\n                        <li><strong>果香突出</strong>：天然花香與莓果香氣是衣索比亞咖啡的招牌風味</li>\n                        <li><strong>酸度明亮</strong>：高海拔賦予其活潑的果酸，清爽而不刺激</li>\n                        <li><strong>茶感明顯</strong>：口感圓潤，入喉後帶有淡淡的茶香，回甘綿長</li>\n                        <li><strong>複雜度高</strong>：單一豆子就能展現多層次風味變化</li>\n                    </ul>\n                    \n                    <div class=\"highlight-box\">\n                        <h4>✨ 推薦指數：⭐⭐⭐⭐</h4>\n                        <p>衣索比亞咖啡適合用於品鑑練習或特殊場合享受，首次購買建議選擇<strong>耶加雪菲或古吉產區</strong>。預算若有限，可透過沐晴咖啡的練功包先體驗。</p>\n                    </div>\n                </section>\n                \n                <hr class=\"divider\">\n                \n                <!-- 哥斯大黎加 -->\n                <section id=\"costarica\">\n                    <h2>二、哥斯大黎加咖啡：中美洲的甜蜜瑰寶</h2>\n                    \n                    <h3>地理位置與氣候特點</h3>\n                    <p>哥斯大黎加位於中美洲，介於太平洋與加勒比海之間。國內地形多為山區高地，主要咖啡產區集中在中央山谷、塔拉蘇和西部山谷等地。</p>\n                    \n                    <div class=\"image-placeholder tall\">\n                     <img src=\"https://img.1shop.tw/e2mJZnvrG0rg7v5AKPba5qkd/o7KQGvx83OMyrnkjNnVR9Xkj/original.png\" alt=\"哥斯大黎加咖啡產區\">\n                    </div>\n                    <div class=\"image-caption\">圖 2-1：哥斯大黎加主要咖啡產區分佈</div>\n                    \n                    <h3>咖啡豆特性與風味傾向</h3>\n                    <p>哥斯大黎加咖啡以<strong>甜感突出、均衡柔和</strong>著稱：</p>\n                    <ul>\n                        <li><strong>天然甜感</strong>：焦糖、巧克力、堅果香是其標誌風味</li>\n                        <li><strong>酸度溫和</strong>：中等酸度，貢獻清爽度</li>\n                        <li><strong>口感厚實</strong>：油脂感明顯，入喉柔順圓潤</li>\n                        <li><strong>穩定性高</strong>：產地穩定，買到地雷的機率最低</li>\n                    </ul>\n                    \n                    <div class=\"success-box\">\n                        <h4>🎯 新手首選</h4>\n                        <p>哥斯大黎加是最推薦新手購買的產地。寬容度最高，適合各種沖泡方式，價格合理，品質穩定。</p>\n                    </div>\n                </section>\n                \n                <hr class=\"divider\">\n                \n                <!-- 秘魯 -->\n                <section id=\"peru\">\n                    <h2>三、秘魯咖啡：安地斯山脈的隱藏寶藏</h2>\n                    \n                    <h3>地理位置與氣候特點</h3>\n                    <p>秘魯位於南美洲西部，安地斯山脈縱貫全境。秘魯的主要咖啡產區分佈在叢林邊界地帶，平均海拔1,200-1,800公尺。</p>\n                    \n                    <h3>咖啡豆特性與風味傾向</h3>\n                    <p>秘魯咖啡是<strong>被低估的瑰寶</strong>，具備以下特徵：</p>\n                    <ul>\n                        <li><strong>多層次感</strong>：堅果、巧克力、香料與微妙的果香交織</li>\n                        <li><strong>醇厚口感</strong>：油脂感豐富，入喉厚重飽滿</li>\n                        <li><strong>平衡度高</strong>：酸度、甜度、苦度搭配得當</li>\n                        <li><strong>性價比高</strong>：價格往往比同級哥倫比亞豆便宜15-25%</li>\n                    </ul>\n                    \n                    <div class=\"image-placeholder\">\n                        <img src=\"https://img.1shop.tw/e2mJZnvrG0rg7v5AKPba5qkd/v5zx6meKY4vkm2z4l0DVkLyo/original.png\" alt=\"秘魯咖啡風味輪\">\n                    </div>\n                    <div class=\"image-caption\">圖 3-1：秘魯咖啡特徵風味分析</div>\n                </section>\n                \n                <hr class=\"divider\">\n                \n                <!-- 哥倫比亞 -->\n                <section id=\"colombia\">\n                    <h2>四、哥倫比亞咖啡：風味與產量的完美平衡</h2>\n                    \n                    <h3>地理位置與氣候特點</h3>\n                    <p>哥倫比亞位於南美洲西北部，安地斯山脈的三條縱谷提供了多樣化的微氣候環境。咖啡產區海拔範圍800-2,200公尺。</p>\n                    \n                    <h3>咖啡豆特性與風味傾向</h3>\n                    <p>哥倫比亞咖啡被稱為<strong>「全能型咖啡豆」</strong>：</p>\n                    <ul>\n                        <li><strong>均衡的風味檔案</strong>：中等酸度、中等醇厚度、適度甜感</li>\n                        <li><strong>堅果與可可香</strong>：焙度越深，巧克力與烤堅果香越濃郁</li>\n                        <li><strong>通用性最強</strong>：最適合作為日常咖啡享用</li>\n                        <li><strong>多產區差異</strong>：同一國家內產區差異大，選擇多樣</li>\n                    </ul>\n                </section>\n                \n                <hr class=\"divider\">\n                \n                <!-- 巴西 -->\n                <section id=\"brazil\">\n                    <h2>五、巴西咖啡：產量與甜感的代名詞</h2>\n                    \n                    <h3>地理位置與氣候特點</h3>\n                    <p>巴西是全球最大咖啡生產國，全球咖啡供應量的三分之一來自巴西。主要咖啡產區位於巴西東南部。</p>\n                    \n                    <h3>咖啡豆特性與風味傾向</h3>\n                    <p>巴西咖啡以<strong>極高的甜感</strong>與<strong>低酸度</strong>著稱：</p>\n                    <ul>\n                        <li><strong>天然甜感最高</strong>：焦糖、巧克力、葡萄乾、蜜糖香氣層出不窮</li>\n                        <li><strong>低酸度友善</strong>：胃酸敏感者可安心享受</li>\n                        <li><strong>厚重醇厚感</strong>：油脂豐富，口感濃郁</li>\n                        <li><strong>烘焙寬容度高</strong>：從淺焙到深焙都能展現甜感</li>\n                    </ul>\n                    \n                    <div class=\"highlight-box\">\n                        <h4>💰 預算優先</h4>\n                        <p>巴西咖啡產量大、價格親民，是預算有限但不想妥協品質的首選。預算<300元/100g就能買到優質巴西豆。</p>\n                    </div>\n                </section>\n                \n                <hr class=\"divider\">\n                \n                <!-- 產地對比表 -->\n                <section id=\"comparison\">\n                    <h2>六、五大咖啡產地一覽表</h2>\n                    \n                    <table>\n                        <thead>\n                            <tr>\n                                <th>產地</th>\n                                <th>海拔</th>\n                                <th>主要特色</th>\n                                <th>推薦焙度</th>\n                                <th>新手友善度</th>\n                            </tr>\n                        </thead>\n                        <tbody>\n                            <tr>\n                                <td><strong>衣索比亞</strong></td>\n                                <td>1,500-2,200m</td>\n                                <td>花果香、明亮酸度、茶感</td>\n                                <td>淺-中焙</td>\n                                <td>⭐⭐</td>\n                            </tr>\n                            <tr>\n                                <td><strong>哥斯大黎加</strong></td>\n                                <td>1,000-1,900m</td>\n                                <td>焦糖甜、均衡感、穩定性</td>\n                                <td>中-深焙</td>\n                                <td>⭐⭐⭐⭐⭐</td>\n                            </tr>\n                            <tr>\n                                <td><strong>秘魯</strong></td>\n                                <td>1,200-1,800m</td>\n                                <td>堅果、巧克力、多層次感</td>\n                                <td>中焙</td>\n                                <td>⭐⭐⭐⭐</td>\n                            </tr>\n                            <tr>\n                                <td><strong>哥倫比亞</strong></td>\n                                <td>800-2,200m</td>\n                                <td>均衡檔案、堅果香、通用性</td>\n                                <td>中焙</td>\n                                <td>⭐⭐⭐⭐⭐</td>\n                            </tr>\n                            <tr>\n                                <td><strong>巴西</strong></td>\n                                <td>600-1,200m</td>\n                                <td>極甜感、低酸度、濃郁</td>\n                                <td>深-極深焙</td>\n                                <td>⭐⭐⭐⭐⭐</td>\n                            </tr>\n                        </tbody>\n                    </table>\n                </section>\n                \n                <hr class=\"divider\">\n                \n                <!-- 購買指南 -->\n                <section id=\"purchase\">\n                    <h2>七、咖啡豆購買決策地圖</h2>\n                    \n                    <h3>根據口味偏好選擇</h3>\n                    <p>以下是快速選購指南，根據你的口味偏好找到最適合的咖啡豆：</p>\n                    <ul>\n                        <li><strong>喜歡花果香、高酸度</strong> → 衣索比亞</li>\n                        <li><strong>喜歡焦糖甜、均衡感</strong> → 哥斯大黎加</li>\n                        <li><strong>喜歡堅果巧克力、多層次</strong> → 秘魯</li>\n                        <li><strong>喜歡全能型、日常搭配</strong> → 哥倫比亞</li>\n                        <li><strong>喜歡極甜感、低酸度</strong> → 巴西</li>\n                    </ul>\n                    \n                    <h3>根據使用場景選擇</h3>\n                    <table>\n                        <thead>\n                            <tr>\n                                <th>使用場景</th>\n                                <th>推薦產地</th>\n                                <th>原因</th>\n                            </tr>\n                        </thead>\n                        <tbody>\n                            <tr>\n                                <td><strong>早晨提神</strong></td>\n                                <td>衣索比亞、哥倫比亞</td>\n                                <td>酸度明亮、層次豐富，幫助大腦清醒</td>\n                            </tr>\n                            <tr>\n                                <td><strong>餐後享受</strong></td>\n                                <td>哥斯大黎加、巴西</td>\n                                <td>甜感突出，消解油膩感</td>\n                            </tr>\n                            <tr>\n                                <td><strong>下午放鬆</strong></td>\n                                <td>秘魯</td>\n                                <td>平衡感強，不會過度刺激</td>\n                            </tr>\n                            <tr>\n                                <td><strong>晚間社交</strong></td>\n                                <td>哥倫比亞</td>\n                                <td>通用性強，適合與他人分享</td>\n                            </tr>\n                            <tr>\n                                <td><strong>冷萃飲品</strong></td>\n                                <td>巴西、哥斯大黎加</td>\n                                <td>甜感完整保留，冷飲口感更佳</td>\n                            </tr>\n                        </tbody>\n                    </table>\n                </section>\n                \n                <hr class=\"divider\">\n                \n                <!-- 品鑑技巧 -->\n                <section id=\"tasting\">\n                    <h2>八、咖啡豆品鑑的五感體驗</h2>\n                    \n                    <p>真正的咖啡品鑑不只是品嚐，而是一場全身心的體驗。</p>\n                    \n                    <h3>1. 視覺（Visual）</h3>\n                    <p>觀察咖啡豆的色澤，了解烘焙程度。不同烘焙度的豆子呈現不同的外觀特徵。</p>\n                    <div class=\"image-placeholder\">\n                        <img src=\"https://img.1shop.tw/e2mJZnvrG0rg7v5AKPba5qkd/7QBw2oEnYzJv1VBQYxAP0vM9/original.png\" alt=\"咖啡豆烘焙度對比\">\n                    </div>\n                    <div class=\"image-caption\">圖 8-1：淺焙、中焙、深焙咖啡豆外觀對比</div>\n                    \n                    <h3>2. 嗅覺（Aroma）</h3>\n                    <p>磨粉後立即聞香，香氣是風味的預告。注意<strong>乾香</strong>（磨粉直後）、<strong>濕香</strong>（熱水注入後）和<strong>尾香</strong>（冷卻後）的變化。</p>\n                    \n                    <h3>3. 味覺（Taste）</h3>\n                    <p>小口品嚐，讓咖啡在舌尖停留數秒。感受<strong>前段香氣</strong>（初始風味）、<strong>中段風味</strong>（核心特徵）和<strong>尾韻</strong>（餘韻）。</p>\n                    \n                    <h3>4. 口感（Mouthfeel）</h3>\n                    <p>評估咖啡的質地與觸覺印象，包括：</p>\n                    <ul>\n                        <li><strong>酸度</strong>：不是壞味道，而是活潑度與複雜度的體現</li>\n                        <li><strong>醇厚度（Body）</strong>：油脂與顆粒物帶來的飽滿感</li>\n                        <li><strong>甜感</strong>：來自咖啡豆本身的天然糖分</li>\n                    </ul>\n                    \n                    <h3>5. 整體評分（Overall）</h3>\n                    <p>綜合上述四項，給予總體評分。建議記錄方式：</p>\n                    <div class=\"highlight-box\">\n                        <p><strong>豆子名稱</strong> | <strong>香氣(★★★)</strong> | <strong>甜度(★★★)</strong> | <strong>酸度(★★★)</strong> | <strong>複雜度(★★★)</strong> | <strong>總評(★★★★)</strong></p>\n                    </div>\n                </section>\n                \n                <hr class=\"divider\">\n                \n                <!-- FAQ -->\n                <section id=\"faq\">\n                    <h2>九、購買前的常見問題</h2>\n                    \n                    <div class=\"faq-section\">\n                        <div class=\"faq-item\">\n                            <div class=\"faq-question\">\n                                <span>Q1：我怕買錯豆子怎麼辦？</span>\n                                <div class=\"faq-toggle\">▼</div>\n                            </div>\n                            <div class=\"faq-answer\">\n                                <p>這是最常見的購買猶豫。<strong>解決方案很簡單：先買練功包。</strong> 1,500元體驗8款豆子，比1,500元買一款不喜歡的豆子聰明多了。而且練功包會告訴你到底喜歡什麼，下一次購買就不會再錯。</p>\n                            </div>\n                        </div>\n                        \n                        <div class=\"faq-item\">\n                            <div class=\"faq-question\">\n                                <span>Q2：練功包值得買嗎？會不會是營銷噱頭？</span>\n                                <div class=\"faq-toggle\">▼</div>\n                            </div>\n                            <div class=\"faq-answer\">\n                                <p>完全值得。計算一下：同樣8款豆子分別購買要2,500-3,500元，練功包只要1,500元。而且官方已經幫你篩選代表性豆子，省時省力。唯一「損失」是豆子用量小（每款25-50g），但這正好適合品鑑練習。</p>\n                            </div>\n                        </div>\n                        \n                        <div class=\"faq-item\">\n                            <div class=\"faq-question\">\n                                <span>Q3：新手一定要買磨豆機嗎？</span>\n                                <div class=\"faq-toggle\">▼</div>\n                            </div>\n                            <div class=\"faq-answer\">\n                                <p>不一定。建議購買順序是：</p>\n                                <ol>\n                                    <li>練功包（1,500元）- 確認口味</li>\n                                    <li>簡單手沖組（300-500元）- 濾紙+濾杯就夠</li>\n                                    <li>溫度計+咖啡秤（300-500元）- 提升成功率</li>\n                                    <li>磨豆機或咖啡機（500-5,000元）- 看預算</li>\n                                </ol>\n                                <p>不用一次買齊。邊用邊升級效果最好。</p>\n                            </div>\n                        </div>\n                        \n                        <div class=\"faq-item\">\n                            <div class=\"faq-question\">\n                                <span>Q4：同一產地的咖啡風味為何會有差異？</span>\n                                <div class=\"faq-toggle\">▼</div>\n                            </div>\n                            <div class=\"faq-answer\">\n                                <p>即使同一產地，不同年份、不同海拔、不同處理方法、不同烘焙度都會影響最終風味。這也是咖啡的魅力所在——永遠有新的發現。</p>\n                            </div>\n                        </div>\n                        \n                        <div class=\"faq-item\">\n                            <div class=\"faq-question\">\n                                <span>Q5：咖啡豆的新鮮度如何判斷？</span>\n                                <div class=\"faq-toggle\">▼</div>\n                            </div>\n                            <div class=\"faq-answer\">\n                                <p>查看包裝上的<strong>烘焙日期</strong>，最佳賞味期為烘焙後1-4週。過新的豆子（3天內）尚未充分釋放香氣，過舊的豆子（超過3個月）風味會逐漸衰退。</p>\n                            </div>\n                        </div>\n                        \n                        <div class=\"faq-item\">\n                            <div class=\"faq-question\">\n                                <span>Q6：是否應該購買最昂貴的咖啡豆？</span>\n                                <div class=\"faq-toggle\">▼</div>\n                            </div>\n                            <div class=\"faq-answer\">\n                                <p>不一定。昂貴的咖啡豆通常因為稀有性或限量版而定價，不一定比中等價位的豆子好喝。選擇符合自己口味與預算的咖啡豆才是正確方式。</p>\n                            </div>\n                        </div>\n                        \n                        <div class=\"faq-item\">\n                            <div class=\"faq-question\">\n                                <span>Q7：能否混合不同產地的咖啡豆？</span>\n                                <div class=\"faq-toggle\">▼</div>\n                            </div>\n                            <div class=\"faq-answer\">\n                                <p>完全可以！這就是「拼配（Blend）」的藝術。混合衣索比亞的花果香與巴西的甜感，可以創造出獨特的風味組合。許多商業咖啡館都使用拼配豆子來達到穩定的風味。</p>\n                            </div>\n                        </div>\n                        \n                        <div class=\"faq-item\">\n                            <div class=\"faq-question\">\n                                <span>Q8：哥斯大黎加和秘魯看起來很像，該選誰？</span>\n                                <div class=\"faq-toggle\">▼</div>\n                            </div>\n                            <div class=\"faq-answer\">\n                                <p><strong>哥斯大黎加</strong>：甜感更高，新手友善度⭐⭐⭐⭐⭐，價格400-500元</p>\n                                <p><strong>秘魯</strong>：平衡感更強，性價比最優⭐⭐⭐⭐，價格250-400元</p>\n                                <p>第一次買推薦秘魯（更便宜，不失風味複雜度）；就是喜歡甜推薦哥斯大黎加。</p>\n                            </div>\n                        </div>\n                        \n                        <div class=\"faq-item\">\n                            <div class=\"faq-question\">\n                                <span>Q9：我怕家裡沒地方放沖泡工具</span>\n                                <div class=\"faq-toggle\">▼</div>\n                            </div>\n                            <div class=\"faq-answer\">\n                                <p>空間擔憂可以解決：</p>\n                                <ul>\n                                    <li><strong>最小套組</strong>：只需一個濾杯（可放廚櫃角落）</li>\n                                    <li><strong>咖啡機方案</strong>：一台機器搞定，佔據空間反而更少</li>\n                                </ul>\n                            </div>\n                        </div>\n                        \n                        <div class=\"faq-item\">\n                            <div class=\"faq-question\">\n                                <span>Q10：我看到很多人推薦衣索比亞，我必須喜歡嗎？</span>\n                                <div class=\"faq-toggle\">▼</div>\n                            </div>\n                            <div class=\"faq-answer\">\n                                <p><strong>完全不是。</strong>咖啡館推薦衣索比亞通常因為利潤高或行銷噱頭。信任你的舌頭，不要被行銷迷惑。如果你通過練功包發現自己更喜歡巴西的甜感，那就大膽選巴西，沒有「正確答案」。</p>\n                            </div>\n                        </div>\n                    </div>\n                </section>\n                \n                <hr class=\"divider\">\n                \n                <!-- 結尾號召 -->\n                <section class=\"cta-section\">\n                    <h3>準備開始你的咖啡升級之旅？</h3>\n                    <p>現在你比90%的咖啡消費者懂得更多。真正的差別，將從你的下一步行動開始。</p>\n                    <p><strong>建議購買順序：</strong><br>\n                    1️⃣ 這週訂練功包 → 2️⃣ 準備沖泡工具 → 3️⃣ 開始品鑑記錄</p>\n                    <a href=\"#\" class=\"cta-button\">購買沐晴咖啡練功包</a>\n                    <a href=\"#\" class=\"cta-button\" style=\"background-color: var(--color-accent-light); border-color: var(--color-accent-light);\">了解Matrix M2 Pro</a>\n                </section>\n            </div>\n        </article>\n    </main>\n\n    \n    <!-- JavaScript 互動 -->\n    <script>\n        // FAQ 折疊功能\n        document.querySelectorAll('.faq-question').forEach(question => {\n            question.addEventListener('click', () => {\n                const item = question.closest('.faq-item');\n                item.classList.toggle('open');\n            });\n        });\n        \n        // 行動版 TOC 切換\n        const tocToggle = document.getElementById('tocToggle');\n        const tocMenu = document.getElementById('tocMenu');\n        \n        tocToggle?.addEventListener('click', () => {\n            tocMenu.classList.toggle('show');\n        });\n        \n        // 點擊目錄項目時關閉行動版菜單\n        document.querySelectorAll('.toc-mobile-menu a').forEach(link => {\n            link.addEventListener('click', () => {\n                tocMenu.classList.remove('show');\n            });\n        });\n        \n        // TOC 主動標記當前章節\n        window.addEventListener('scroll', () => {\n            const sections = document.querySelectorAll('section[id]');\n            const tocLinks = document.querySelectorAll('.toc-list a');\n            \n            let current = '';\n            sections.forEach(section => {\n                const sectionTop = section.offsetTop;\n                if (scrollY >= sectionTop - 100) {\n                    current = section.getAttribute('id');\n                }\n            });\n            \n            tocLinks.forEach(link => {\n                link.classList.remove('active');\n                if (link.getAttribute('href') === `#${current}`) {\n                    link.classList.add('active');\n                }\n            });\n        });\n        \n        // 平滑滾動（不支援時的備選）\n        if (!CSS.supports('scroll-behavior', 'smooth')) {\n            document.documentElement.style.scrollBehavior = 'auto';\n        }\n    </script>\n",
